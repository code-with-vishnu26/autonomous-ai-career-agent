# Autonomous AI Career Agent — example environment file.
# Copy to `.env` and fill in your own values. NEVER commit your real `.env`.
# This is a single-user, self-hosted tool: these are *your* keys and accounts.

# --- LLM provider (one is required; Groq is tried first, free tier) ---
GROQ_API_KEY=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
ANTHROPIC_API_KEY=

# --- Web search providers (Discovery, optional; failover order) ---
EXA_API_KEY=
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# --- Gmail (Apply: email-to-apply, optional) ---
# OAuth is performed manually by you; the agent never automates Google OAuth.
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json

# --- Storage ---
DATABASE_PATH=data/career_agent.db

# --- Runtime ---
LOG_LEVEL=INFO
