# Autonomous AI Career Agent — example environment file.
# Copy to `.env` and fill in your own values. NEVER commit your real `.env`.
# This is a single-user, self-hosted tool: these are *your* keys and accounts.

# --- LLM provider (one is required; Groq is tried first, free tier) ---
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# --- Web search providers (Discovery, optional; failover order) ---
EXA_API_KEY=
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# --- Gmail (Apply: email-to-apply, optional) ---
# OAuth is performed manually by you; the agent never automates Google OAuth.
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json

# --- Worldwide job-board discovery (Phase 12, ADR-0036, optional) ---
# Arbeitnow/TheMuse/Remotive/RemoteOK need no key (enabled by default
# below). Everything else here is opt-in: a source is only wired up when
# its key is present.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRIES=gb,in,us
REED_API_KEY=
USAJOBS_API_KEY=
USAJOBS_USER_AGENT=
JOOBLE_API_KEY=
JOOBLE_LOCATION=
DISCOVERY_KEYWORDS=software engineer
ARBEITNOW_ENABLED=true
THEMUSE_ENABLED=true
REMOTIVE_ENABLED=true
REMOTEOK_ENABLED=true

# --- Notification delivery channels (Phase 16, ADR-0040, optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
NTFY_TOPIC=

# --- Storage ---
DATABASE_PATH=data/career_agent.db

# --- Web Dashboard API (career-agent serve, Phase 56) ---
# Required to start the API -- it refuses to sign/verify sessions without
# it. Generate your own: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=
# The CLI's fixed, auto-provisioned "local operator" account (no login
# flow for the CLI itself) -- only matters if you also run the dashboard.
CLI_LOCAL_USER_EMAIL=local@career-agent.local

# --- Notifications & background processing (Phase 58) ---
# Unset means real email delivery is disabled -- attempts are recorded as
# skipped, never faked as sent. Set SMTP_HOST + SMTP_FROM_ADDRESS together
# to enable it.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_ADDRESS=
REMINDER_INTERVAL_MINUTES=60
NOTIFICATION_RETENTION_DAYS=30

# --- Organizations & billing (Phase 60) ---
# Used only to build an absolute accept-invitation link inside an
# invitation email. Set to your real frontend origin in production.
FRONTEND_BASE_URL=http://localhost:5173

# --- Résumé upload + Excel résumé-PDF links (Phase 71) ---
# Where this API is actually reachable from outside the app -- used only
# to build the absolute, signed résumé-download link inside an exported
# Excel workbook (opened later from Excel itself, with no browser origin
# to resolve a relative path against). Set to your real public API origin
# in production (e.g. https://api.example.com, or https://example.com if
# the edge proxy fronts both frontend and backend on one origin).
API_BASE_URL=http://localhost:8000

# --- Runtime ---
LOG_LEVEL=INFO
