# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
downloads/
*.egg-info/
.eggs/
*.egg
.installed.cfg

# ---- Virtual environments ----
.venv/
venv/
env/
ENV/

# ---- Testing / coverage ----
.pytest_cache/
.mypy_cache/
.ruff_cache/
.import_linter_cache/
.coverage

# ---- Agent/editor session state (never intended to ship, Phase 41) ----
.claude/
.coverage.*
htmlcov/
.tox/
.nox/

# ---- Tooling ----
.idea/
.vscode/
*.swp
.DS_Store

# ---- Secrets & local config (single-user, self-hosted) ----
.env
.env.*
!.env.example
*.pem
*.key
credentials.json

# ---- Docker/production env (Phase 59, ADR-0076) -- docker.env and
# production.env.example are safe, tracked templates; a real filled-in
# production.env is not. ----
production.env
!production.env.example
certs/
token.json
gmail_token*.json

# ---- Application data (the user's own data stays local) ----
*.db
*.sqlite
*.sqlite3
data/
exports/
*.xlsx
master_profile.json
!examples/**/master_profile.json
# The actual default master-profile filename every command/README uses
# (Phase 46 finding: only the unused "master_profile.json" pattern above
# was ever ignored -- this real default was never covered).
/profile.json
# Job Search Preferences (Phase 46, ADR-0064): the user's own search
# configuration, same "stays local" treatment as the master profile.
/job_preferences.json

# ---- promptfoo live-validation evidence (machine-local, never committed) ----
# See promptfoo/README.md: these are the artifacts verify_promptfoo_results
# checks structurally/by content, never cryptographically -- committing one
# would misleadingly imply "checked into version control" means "verified",
# when a fabricated file with the right counters would look identical.
# Every developer/CI environment must produce its own by running the real
# suite (promptfoo/README.md's "Running it" section).
promptfoo/results/

# ---- Browser / Playwright session state ----
.auth/
playwright/.cache/
browser_state*.json

# ---- Logs ----
*.log
logs/

# ---- Node / frontend (Phase 55) ----
# frontend/.gitignore already covers this for git itself; also listed here
# because hatchling's sdist file-selection only consults the *root*
# .gitignore, not nested ones (the same class of gap ADR-0061 found for
# .claude/.import_linter_cache/ -- confirmed live: node_modules leaked into
# a built sdist despite frontend/.gitignore ignoring it for git). dist/
# (frontend's build output) is already covered by the generic dist/ pattern
# above.
node_modules/

# ---- Local Phase 36 controlled-smoke evidence/fixtures (never committed) ----
# Named exactly, not by wildcard, so this can never silently hide an
# unrelated legitimate file -- see docs/adr/0058-confirmation-lifecycle-and-retry-semantics.md.
/phase36_evidence.txt
/phase36_local_smoke.ps1
/phase36_smoke/
/synthetic_opportunity.json
/synthetic_profile.json
