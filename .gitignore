# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
downloads/
*.egg-info/
.eggs/
*.egg
.installed.cfg

# ---- Virtual environments ----
.venv/
venv/
env/
ENV/

# ---- Testing / coverage ----
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# ---- Tooling ----
.idea/
.vscode/
*.swp
.DS_Store

# ---- Secrets & local config (single-user, self-hosted) ----
.env
.env.*
!.env.example
*.pem
*.key
credentials.json
token.json
gmail_token*.json

# ---- Application data (the user's own data stays local) ----
*.db
*.sqlite
*.sqlite3
data/
exports/
*.xlsx
master_profile.json
!examples/**/master_profile.json

# ---- promptfoo live-validation evidence (machine-local, never committed) ----
# See promptfoo/README.md: these are the artifacts verify_promptfoo_results
# checks structurally/by content, never cryptographically -- committing one
# would misleadingly imply "checked into version control" means "verified",
# when a fabricated file with the right counters would look identical.
# Every developer/CI environment must produce its own by running the real
# suite (promptfoo/README.md's "Running it" section).
promptfoo/results/

# ---- Browser / Playwright session state ----
.auth/
playwright/.cache/
browser_state*.json

# ---- Logs ----
*.log
logs/

# ---- Local Phase 36 controlled-smoke evidence/fixtures (never committed) ----
# Named exactly, not by wildcard, so this can never silently hide an
# unrelated legitimate file -- see docs/adr/0058-confirmation-lifecycle-and-retry-semantics.md.
/phase36_evidence.txt
/phase36_local_smoke.ps1
/phase36_smoke/
/synthetic_opportunity.json
/synthetic_profile.json
