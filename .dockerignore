# Keeps build context small and secrets out of any image layer.
.git
.github
.venv
venv
__pycache__
*.pyc
*.pyo
.pytest_cache
.ruff_cache
.import_linter_cache
.mypy_cache
.claude
dist
build
*.egg-info
data/
promptfoo/results/
.env
.env.*
!.env.example
production.env
*.pem
*.key
credentials.json
token.json
career_agent.db

# Frontend: node_modules and its own build output are rebuilt inside the
# image (Dockerfile.frontend's builder stage), never copied from the host.
frontend/node_modules
frontend/dist
frontend/coverage

docs/
docker-compose*.yml
