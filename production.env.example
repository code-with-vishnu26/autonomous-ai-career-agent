# Production environment example (Phase 59, ADR-0076). Copy to
# `production.env`, fill in real values, and pass it explicitly:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml \
#     --env-file production.env up -d
# NEVER commit the filled-in file -- see .gitignore.

ENVIRONMENT=production
LOG_LEVEL=INFO
JSON_LOGS=true

# --- Required: at least one LLM provider ---
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# --- Required: dashboard auth. Generate your own, never reuse this file's
# placeholder or any value checked into version control:
# python -c "import secrets; print(secrets.token_urlsafe(32))" ---
JWT_SECRET_KEY=
CLI_LOCAL_USER_EMAIL=
JWT_COOKIE_SECURE=true

# --- Storage (container-internal paths; leave as-is unless you also
# change the volume mounts) ---
DATABASE_PATH=/app/data/career_agent.db
ARTIFACTS_DIR=/app/data/artifacts
BROWSER_SESSION_DIR=/app/data/sessions
PROMPTFOO_RESULTS_DIR=/app/promptfoo/results

# --- PostgreSQL (accepted, not yet consumed -- see ADR-0076). Only
# matters if you run the `postgres` Compose profile. ---
DATABASE_URL=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# --- Notifications & background processing (Phase 58, ADR-0077). Unset
# SMTP means real email delivery is disabled -- attempts are recorded as
# skipped, never faked as sent. ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_ADDRESS=
REMINDER_INTERVAL_MINUTES=60
NOTIFICATION_RETENTION_DAYS=30

# --- Organizations & billing (Phase 60) -- set to your real frontend
# origin; used only to build an absolute accept-invitation link. ---
FRONTEND_BASE_URL=

# --- Optional: worldwide job-board discovery keys, notifications, etc. --
# see .env.example for the full list this project supports. Every one of
# them is optional; unset simply disables that specific integration. ---
