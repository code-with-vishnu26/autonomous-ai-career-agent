# Default environment for `docker compose up` (Phase 59, ADR-0076).
# Safe to commit: no real secrets, only local-dev-safe placeholders.
# Copy this to `.env` and fill in real values for anything you need
# working (an LLM key, web-search keys, ...), or pass a second env file
# via `docker compose --env-file .env up` to layer your own secrets on
# top without editing this tracked file.

ENVIRONMENT=production
LOG_LEVEL=INFO
JSON_LOGS=true

# --- LLM provider (required for tailoring/truthfulness-gate/Career Coach
# AI features; leave unset and those features report unavailable rather
# than silently no-op) ---
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# --- Web Dashboard auth (Phase 56) -- REQUIRED. Generate your own:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=
CLI_LOCAL_USER_EMAIL=local@career-agent.local
# Set true once served over real HTTPS (see docs/deployment/production.md).
JWT_COOKIE_SECURE=false

# --- Storage (container-internal paths -- do not change unless you also
# change the matching volume mount in docker-compose.yml) ---
DATABASE_PATH=/app/data/career_agent.db
ARTIFACTS_DIR=/app/data/artifacts
BROWSER_SESSION_DIR=/app/data/sessions
PROMPTFOO_RESULTS_DIR=/app/promptfoo/results

# --- PostgreSQL (accepted, not yet consumed by the storage layer --
# see ADR-0076) ---
DATABASE_URL=
POSTGRES_DB=career_agent
POSTGRES_USER=career_agent
POSTGRES_PASSWORD=career_agent
